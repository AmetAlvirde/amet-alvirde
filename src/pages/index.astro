---
import "../styles/global.css";
import "../styles/site.css";
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import MonogramDisplay from '../components/MonogramDisplay.astro';
import meditationIcon from '../assets/meditation-icon.svg?raw';
---

<BaseLayout>
	<Navigation />

	<main class="w-full max-w-md mx-auto px-4 pt-20 pb-16">
		<div class="flex justify-center items-center mb-4 md:mb-14">
			<MonogramDisplay />
		</div>

		<div class="flex flex-col w-full">
			<nav class="flex flex-col" aria-label="Navegación principal">
				<div class="relative mb-4">
					<div class="flex items-center justify-between border-2 border-accent bg-accent text-accent-foreground no-underline transition-all duration-150 w-full relative gap-4 py-8 px-6 border-t-2 cursor-default mb-2 pointer-events-none touch-none md:py-10 md:px-8">
						<div class="flex flex-col gap-1.5 flex-1">
							<span class="text-xl font-bold uppercase tracking-[0.2em] leading-tight md:text-2xl">Amet Alvirde</span>
							<span class="text-base font-medium text-accent-foreground opacity-80 md:text-lg">Soy como tú</span>
						</div>
						<div class="flex items-center justify-center shrink-0 text-accent-foreground w-6 h-7 [&>*]:w-full [&>*]:h-full md:w-7 md:h-8" aria-hidden="true" set:html={meditationIcon.replace('fill="#000000"', 'fill="currentColor"')}></div>
					</div>
				</div>

				<a href="/writing" class="flex items-center justify-between border-2 border-border border-t-2 bg-surface text-foreground no-underline transition-all duration-150 w-full relative gap-4 py-7 px-5 md:py-8 md:px-6 [@media(hover:hover)]:hover:border-accent active:border-accent focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 [-webkit-tap-highlight-color:transparent]">
					<div class="flex flex-col gap-1.5 flex-1">
						<span class="text-base font-bold uppercase tracking-[0.2em] leading-tight text-foreground md:text-lg">TEXTOS</span>
						<span class="text-xs font-normal normal-case tracking-[0.01em] leading-snug text-muted md:text-sm">Escribo para explorar mi consciencia</span>
					</div>
					<span class="flex items-center shrink-0 text-base">
						<span class="text-lg font-normal leading-none md:text-xl">→</span>
					</span>
				</a>

				<a href="#" class="flex items-center justify-between border-2 border-t-0 !border-border bg-canvas text-foreground no-underline transition-all duration-150 w-full relative gap-4 py-6 px-5 md:py-7 md:px-6 cursor-not-allowed pointer-events-none [-webkit-tap-highlight-color:transparent]" aria-disabled="true">
					<div class="flex flex-col gap-1.5 flex-1">
						<span class="text-base font-bold uppercase tracking-[0.2em] leading-tight text-muted md:text-lg">SOFTWARE</span>
						<span class="text-xs font-normal normal-case tracking-[0.01em] leading-snug text-muted md:text-sm">Creo apps y herramientas</span>
					</div>
					<span class="text-xs uppercase tracking-[0.2em] font-semibold text-muted">PRONTO</span>
				</a>

				<a href="#" class="flex items-center justify-between border-2 border-t-0 !border-border bg-canvas text-foreground no-underline transition-all duration-150 w-full relative gap-4 py-6 px-5 md:py-7 md:px-6 cursor-not-allowed pointer-events-none [-webkit-tap-highlight-color:transparent]" aria-disabled="true">
					<div class="flex flex-col gap-1.5 flex-1">
						<span class="text-base font-bold uppercase tracking-[0.2em] leading-tight text-muted md:text-lg">Fotos</span>
						<span class="text-xs font-normal normal-case tracking-[0.01em] leading-snug text-muted md:text-sm">Documento el mundo que me rodea</span>
					</div>
					<span class="text-xs uppercase tracking-[0.2em] font-semibold text-muted">PRONTO</span>
				</a>

				<a href="#" class="flex items-center justify-between border-2 border-t-0 !border-border bg-canvas text-foreground no-underline transition-all duration-150 w-full relative gap-4 py-6 px-5 md:py-7 md:px-6 cursor-not-allowed pointer-events-none [-webkit-tap-highlight-color:transparent]" aria-disabled="true">
					<div class="flex flex-col gap-1.5 flex-1">
						<span class="text-base font-bold uppercase tracking-[0.2em] leading-tight text-muted md:text-lg">VIDEOS</span>
						<span class="text-xs font-normal normal-case tracking-[0.01em] leading-snug text-muted md:text-sm">Documento mi experiencia humana</span>
					</div>
					<span class="text-xs uppercase tracking-[0.2em] font-semibold text-muted">PRONTO</span>
				</a>
			</nav>
		</div>
	</main>
</BaseLayout>
