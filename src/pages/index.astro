---
import BaseLayout from "../layouts/base-layout.astro";
import Navigation from "../components/Navigation.astro";
import Cartouche from "../components/cartouche.astro";
import NavTile from "../components/nav-tile.astro";
---

<BaseLayout>
	<Navigation />

	<main id="main-content" class="min-w-[300px] w-full max-w-md mx-auto px-4 pt-32 pb-16">
		<div class="flex flex-col w-full">
			<nav class="flex flex-col" aria-label="Navegación principal">
				<div class="relative mb-4">
					<Cartouche subtitle="Soy como tú" variant="hero" />
				</div>

				<NavTile
					href="/writing"
					title="TEXTOS"
					description="Escribo para explorar mi consciencia"
				/>

				<NavTile
					href="#"
					title="SOFTWARE"
					description="Creo apps y herramientas"
					disabled={true}
					disabledLabel="PRONTO"
				/>

				<NavTile
					href="#"
					title="Fotos"
					description="Documento el mundo que me rodea"
					disabled={true}
					disabledLabel="PRONTO"
				/>

				<NavTile
					href="#"
					title="VIDEOS"
					description="Documento mi experiencia humana"
					disabled={true}
					disabledLabel="PRONTO"
				/>
			</nav>
		</div>
	</main>
</BaseLayout>
