---
import BaseLayout from "../../layouts/base-layout.astro";
import Navigation from "../../components/Navigation.astro";
import ReadContent from "../../components/writing/ReadContent.astro";
import ReadFooter from "../../components/writing/ReadFooter.astro";
import SeriesList from "../../components/writing/SeriesList.astro";
import ReadingControls from "../../components/writing/ReadingControls.tsx";
import { getEntry, render } from "astro:content";
import {
  getReads,
  getFeaturedRead,
  getSeries,
  getSeriesBySlug,
  getReadsBySeries,
} from "../../utils/content";

const [reads, seriesList] = await Promise.all([getReads(), getSeries()]);
const featured = getFeaturedRead(reads);
if (!featured) {
  throw new Error("No featured read found");
}
const entry = await getEntry("reads", featured.slug);
if (!entry) {
  throw new Error(`Read not found: ${featured.slug}`);
}
const { Content } = await render(entry);

const series = getSeriesBySlug(seriesList, featured.seriesSlug);
const readsInSeries = series ? getReadsBySeries(reads, series.reads) : [];
const currentIndex =
  readsInSeries.findIndex((r) => r.slug === featured.slug) ?? 0;

const SITE_URL = "https://www.ametalvirde.com";
const pageTitle = `${featured.title} — Amet Alvirde`;
const pageUrl = `${SITE_URL}/writing/${featured.slug}`;
---

<BaseLayout
	title={pageTitle}
	description={`${featured.title}. ${featured.date}. Lectura de Amet Alvirde.`}
	ogUrl={pageUrl}
	ogImage={series ? (series.image.startsWith("http") ? series.image : `${SITE_URL}${series.image.startsWith("/") ? "" : "/"}${series.image}`) : "https://www.ametalvirde.com/monogram-dark-mode.svg"}
	canonical={pageUrl}
>
	<Navigation />

	<main id="main-content" class="min-w-[300px] w-full max-w-7xl mx-auto px-6 lg:px-12 pt-20">
		<div class="max-w-4xl mx-auto">
			<SeriesList
				seriesList={seriesList}
				activeSeriesSlug={featured.seriesSlug}
			/>
			{series && (
				<div class="max-w-[70ch] mx-auto">
					<ReadingControls
						client:load
						series={series}
						reads={readsInSeries}
						currentIndex={currentIndex >= 0 ? currentIndex : 0}
					/>
				</div>
			)}

			<ReadContent>
				<Content />
			</ReadContent>

			<ReadFooter
				sourceUrl={featured.sourceUrl}
				recommendations={featured.recommendations}
			/>
		</div>
	</main>
</BaseLayout>
