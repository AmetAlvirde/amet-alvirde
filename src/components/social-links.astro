---
import IconButton from "./icon-button.astro";

interface Props {
  /** When "inherit", blends with parent (uses parent bg/foreground) */
  variant?: "default" | "inherit";
}

const { variant = "default" } = Astro.props;
---

<div id="social-links" class={`flex gap-2 ${variant === "inherit" ? "mt-0" : "mt-6"}`}>
	<IconButton
		variant="borderless"
		as="a"
		href="https://twitter.com/ametalvirde"
		target="_blank"
		rel="noopener noreferrer"
		ariaLabel="Twitter / X"
	>
		<i class="ph ph-twitter-logo text-xl" aria-hidden="true"></i>
	</IconButton>

	<IconButton
		variant="borderless"
		as="a"
		href="https://www.instagram.com/ametalvirde/"
		target="_blank"
		rel="noopener noreferrer"
		ariaLabel="Instagram"
	>
		<i class="ph ph-instagram-logo text-xl" aria-hidden="true"></i>
	</IconButton>

	<IconButton
		variant="borderless"
		as="a"
		href="https://www.tiktok.com/@ametalvirde"
		target="_blank"
		rel="noopener noreferrer"
		ariaLabel="TikTok"
	>
		<i class="ph ph-tiktok-logo text-xl" aria-hidden="true"></i>
	</IconButton>
</div>

