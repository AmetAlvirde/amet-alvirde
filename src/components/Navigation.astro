---
import ThemeControls from "./theme-controls.astro";
import IconButton from "./icon-button.astro";

const showBackButton = Astro.url.pathname !== "/" && Astro.url.pathname !== "";
---

<nav
	class="w-full px-6 lg:px-12 py-3 flex justify-between items-center fixed top-0 left-0 right-0 z-50 bg-background text-foreground"
>
	<div class="flex items-center min-w-0">
		{showBackButton && (
			<IconButton
				as="a"
				href="/"
				ariaLabel="Volver al inicio"
				title="Volver al inicio"
				variant="borderless"
			>
				<i class="ph ph-arrow-left shrink-0 text-xl" aria-hidden="true"></i>
			</IconButton>
		)}
	</div>

	<ThemeControls />
</nav>