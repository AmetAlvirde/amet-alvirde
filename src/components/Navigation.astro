---
import ThemeControls from "./theme-controls.astro";
import IconButton from "./icon-button.astro";

const showBackButton = Astro.url.pathname !== "/" && Astro.url.pathname !== "";
---

<nav
	class="w-full px-4 py-3 flex justify-between items-center fixed top-0 left-0 right-0 z-50 border-b-2"
	style="background: var(--bg-primary); border-color: var(--border);"
>
	<div class="flex items-center min-w-0">
		{showBackButton && (
			<IconButton
				as="a"
				href="/"
				ariaLabel="Volver al inicio"
				title="Volver al inicio"
			>
				<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
					<path
						fill-rule="evenodd"
						d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
						clip-rule="evenodd"
					/>
				</svg>
			</IconButton>
		)}
	</div>

	<ThemeControls />
</nav>